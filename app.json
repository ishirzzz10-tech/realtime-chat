{
  "expo": {
    "name": "Realtime Chat",
    "slug": "realtime-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "realtimechat",
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      [
        "expo-image-picker",
        { "photosPermission": "Allow Realtime Chat to access your photos so you can share images." }
      ],
      "expo-notifications"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ishika.realtimechat"
    },
    "android": {
      "package": "com.ishika.realtimechat"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
