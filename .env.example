# --- Supabase connection ---------------------------------------------------
# Copy this file to ".env" and paste your project's values.
# Find them in the Supabase Dashboard: Project Settings -> API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Optional --------------------------------------------------------------
# Route message sends through the "send-message" Edge Function instead of a
# direct insert. Default is a direct insert (works as soon as the SQL is run).
EXPO_PUBLIC_USE_EDGE_FUNCTION=false
